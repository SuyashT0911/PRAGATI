# ============================================================
#  PRAGATI — .gitignore
# ============================================================

# ─── Environment / Secrets ──────────────────────────────────
.env
.env.local
.env.development
.env.production
*.env

# ─── Node / Backend ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json          # keep package.json, ignore lock for portability
                            # (remove this line if you want to commit the lock file)

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── Build / Distribution ───────────────────────────────────
dist/
build/
out/
.cache/
.parcel-cache/

# ─── OS Generated Files ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE / Editor Files ─────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ─── Dev / Utility Scripts (not part of the app) ────────────
frontend/fixer.py

# ─── Temp / Misc ────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
